                            }
                        }
                    }
                )
                custom uniform bool paused (
                    customData = {
                        dictionary omni = {
                            dictionary kit = {
                                bool locked = 0
                            }
                        }
                    }
                )

                def Shader "Shader"
                {
                    uniform token info:implementationSource = "sourceAsset"
                    uniform asset info:mdl:sourceAsset = @OmniPBR.mdl@
                    uniform token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
                    color3f inputs:diffuse_color_constant = (0.099999994, 0.29999998, 0.099999994)
                    color3f inputs:diffuse_tint = (1, 1, 1)
                    token outputs:out (
                        renderType = "material"
                    )
                }
            }

            def Material "Cushion"
            {
                token outputs:mdl:displacement.connect = </World/BilliardEnv/Looks/Cushion/Shader.outputs:out>
                token outputs:mdl:surface.connect = </World/BilliardEnv/Looks/Cushion/Shader.outputs:out>
                token outputs:mdl:volume.connect = </World/BilliardEnv/Looks/Cushion/Shader.outputs:out>

