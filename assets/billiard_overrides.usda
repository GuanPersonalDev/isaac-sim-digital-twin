        def Scope "Looks"
        {
            def Material "TableSurface" (
                customData = {
                    dictionary omni = {
                        dictionary kit = {
                            bool locked = 0
                        }
                    }
                }
            )
            {
                token outputs:displacement (
                    customData = {
                        dictionary omni = {
                            dictionary kit = {
                                bool locked = 0
                            }
                        }
                    }
                )
                token outputs:mdl:displacement (
                    customData = {
                        dictionary omni = {
                            dictionary kit = {
                                bool locked = 0
                            }
                        }
                    }
                )
                token outputs:mdl:displacement.connect = </World/BilliardEnv/Looks/TableSurface/Shader.outputs:out>
                token outputs:mdl:surface (
                    customData = {
                        dictionary omni = {
                            dictionary kit = {
                                bool locked = 0
                            }
                        }
                    }
                )
                token outputs:mdl:surface.connect = </World/BilliardEnv/Looks/TableSurface/Shader.outputs:out>
                token outputs:mdl:volume (
                    customData = {
